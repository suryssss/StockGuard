// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id           String        @id @default(uuid())
  name         String
  ownerName    String?
  whatsappNum  String        @unique
  createdAt    DateTime      @default(now())
  products     Product[]
  distributors Distributor[]
}

model Distributor {
  id           String      @id @default(uuid())
  shopId       String
  shop         Shop        @relation(fields: [shopId], references: [id])
  name         String
  whatsappNum  String?
  batches      Batch[]
  returnLogs   ReturnLog[]
}

model Product {
  id      String  @id @default(uuid())
  shopId  String
  shop    Shop    @relation(fields: [shopId], references: [id])
  name    String
  batches Batch[]
}

model Batch {
  id            String       @id @default(uuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  distributorId String?
  distributor   Distributor? @relation(fields: [distributorId], references: [id])
  batchNumber   String?
  expiryDate    DateTime
  quantity      Int
  purchasePrice Float?
  purchaseDate  DateTime     @default(now())
  alerted60     Boolean      @default(false)
  alerted30     Boolean      @default(false)
  alerted15     Boolean      @default(false)
  alerted7      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  returnLogs    ReturnLog[]
}

model ReturnLog {
  id            String      @id @default(uuid())
  batchId       String
  batch         Batch       @relation(fields: [batchId], references: [id])
  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  sentAt        DateTime    @default(now())
  outcome       String      @default("pending")
}
